# ─── SFMC Server credentials ───────────────────────────────────────────────────
SFMC_HOST=sfmc.webbresearch.com
SFMC_USER=your_username
SFMC_PASSWORD=your_password
# SFMC_KEY=/path/to/ssh_private_key   # alternative to password auth

# Remote path on SFMC server (directory that mirrors to RAW_DIR)
SFMC_REMOTE_PATH=/var/opt/sfmc-dockserver/stations/bergen/gliders/var

# ─── Local storage ──────────────────────────────────────────────────────────────
# Inside the container /app/data is a mounted volume; on the host it's ./data
DATA_DIR=/app/data

# ─── Sync schedule ──────────────────────────────────────────────────────────────
SYNC_INTERVAL_MINUTES=30

# ─── Web app ────────────────────────────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8090
APP_DEBUG=false
