# ─── PhysChem upload ────────────────────────────────────────────────────────────
# After each sync, NPC files are checked against PhysChem and uploaded if missing.
# Leave blank to disable.
PHYSCHEM_BASE_URL=https://physchem-api-test.hi.no
PHYSCHEM_EDITOR_URL=https://physchem-editor.hi.no
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ─── Incoming SFTP server (docker-compose.sftp.yml) ────────────────────────────
# Glider systems push binary files to this server.
# Start with: docker compose -f docker-compose.yml -f docker-compose.sftp.yml up -d
# Show connection info: python sftp_server_info.py
SFTP_USER=glider
SFTP_PASSWORD=change_me_use_a_strong_password
SFTP_LISTEN_PORT=2222

# ─── SFMC Server credentials ───────────────────────────────────────────────────
SFMC_HOST=sfmc.webbresearch.com
SFMC_USER=your_username
SFMC_PASSWORD=your_password
# SFMC_KEY=/path/to/ssh_private_key   # alternative to password auth

# Glider names to sync (comma-separated).  The app constructs the full remote
# paths as  SFMC_BASE_PATH/<glider_name>  for each name listed here.
GLIDER_NAMES=var,fulla

# PhysChem platform IDs keyed by glider name.  Add one entry per glider.
GLIDER_PLATFORM_ID={var:666,fulla:667}

# Base path on the SFMC server under which each glider directory lives.
SFMC_BASE_PATH=/var/opt/sfmc-dockserver/stations/bergen/gliders

# Optional: override with explicit full paths instead of using GLIDER_NAMES.
# SFMC_REMOTE_PATHS=/var/opt/sfmc-dockserver/stations/bergen/gliders/var,/var/opt/sfmc-dockserver/stations/bergen/gliders/fulla

# ─── Local storage ──────────────────────────────────────────────────────────────
# Inside the container /app/data is a mounted volume; on the host it's ./data
DATA_DIR=/app/data

# Directory containing .cac cache files required by dbdreader.
# Defaults to DATA_DIR/cac.  Copy missing .cac files here when the log reports
# "Missing cache file: XXXXXXXX.cac"
CAC_DIR=/app/data/cac

# ─── Sync schedule ──────────────────────────────────────────────────────────────
SYNC_INTERVAL_MINUTES=30

# ─── Web app ────────────────────────────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8090
APP_DEBUG=false
